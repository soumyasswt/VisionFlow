{
  "name": "visionflow-api",
  "version": "1.0.0",
  "description": "Graph Delivery API for VisionFlow",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "proto:generate": "pbjs -t static-module -w commonjs -o src/proto/graph.js ../proto/graph.proto && pbts -o src/proto/graph.d.ts src/proto/graph.js"
  },
  "dependencies": {
    "duckdb": "^1.1.0",
    "fastify": "^5.8.1",
    "ioredis": "^5.10.0",
    "protobufjs": "^7.3.2",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "protobufjs-cli": "^2.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
